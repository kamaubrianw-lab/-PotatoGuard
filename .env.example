# ══════════════════════════════════════════════════════════
#  .env.example  —  Copy to .env and fill in your values
#  NEVER commit the actual .env file to git
# ══════════════════════════════════════════════════════════

# ── REQUIRED ──────────────────────────────────────────────
# Gemini 1.5 Flash API key — get free at:
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# JWT signing secret — generate with:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_random_32_byte_hex_string

# ── OPTIONAL ──────────────────────────────────────────────
# Session duration in minutes (default: 60)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database location (default: SQLite at project root)
DATABASE_URL=sqlite:///./potato_disease.db

# Backend URL used by ui.py (default: local)
API_BASE_URL=http://127.0.0.1:8000
